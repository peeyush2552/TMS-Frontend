# Frontend Environment Variables (REFERENCE ONLY)
# Angular doesn't use .env files directly - this is just for documentation
# 
# ACTUAL configuration is in:
# - src/environments/environment.ts (development)
# - src/environments/environment.production.ts (production)
#
# For Vercel deployment, set environment variable in Vercel Dashboard:
# Variable name: API_URL
# Variable value: https://your-backend-url.vercel.app/api

# Development API URL (used in environment.ts)
DEV_API_URL=http://localhost:5000/api

# Production API URL (used in environment.production.ts)
# Update environment.production.ts with your actual backend URL after deploying
PROD_API_URL=https://your-backend-url.vercel.app/api
